# Anthropic API key (evaluator / summarizer / comparison). Console: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Optional alias (either works):
# CLAUDE_API_KEY=

# Evren API auth: if your Evren service requires API key auth, set this to the same value as the service's AUTH_KEY. Sent as x-api-key header. Name must be exactly EVREN_API_KEY (not evren_api_key).
EVREN_API_KEY=
# Optional: full Authorization value for backends that use Bearer / OIDC (e.g. some Cloud Run setups). Example: Bearer <token>
# EVREN_AUTHORIZATION=

# Evren API URL
NEXT_PUBLIC_EVREN_API_URL=http://localhost:8000

# Supabase (https://supabase.com/dashboard project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
# Required for signup (create users row), add-user, auth sync. Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# Server-only: for syncing auth→USERS and adding users (owner). Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# Fallback user_id for evaluate/run when not logged in (optional if using auth)
DEFAULT_USER_ID=your_default_user_uuid
